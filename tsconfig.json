{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "5.0",
    "rootDir": "./src",
    "allowUnusedLabels": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "module": "Node16",
    "moduleResolution": "Node16",
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "removeComments": false,
    "sourceMap": true,
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom"
    ],
    "pretty": true,
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "compileOnSave": false,
  "buildOnSave": false,
  "ts-node": { 
    "compilerOptions": {
      "module": "commonjs"
    },
    "files": true 
  }
}
